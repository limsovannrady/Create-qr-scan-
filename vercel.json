{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["db.py", "bot_handlers.py"]
      }
    },
    {
      "src": "api/ping.py",
      "use": "@vercel/python"
    },
    {
      "src": "dashboard.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["db.py", "templates/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook.py" },
    { "src": "/api/ping", "dest": "/api/ping.py" },
    { "src": "/(.*)", "dest": "/dashboard.py" }
  ]
}
